# Firebase web app configuration (frontend).
# These are NOT secrets — Firebase web API keys are safe to expose in client code.
# Real security comes from Firestore rules + Auth, not from hiding this key.
# Copy this file to ".env" and fill in the values from your Firebase project:
# Firebase Console -> Project settings -> General -> Your apps -> SDK setup and configuration.

VITE_OPTO_KEY=your_api_key
VITE_OPTO_AUTHDOMAIN=your_project.firebaseapp.com
VITE_OPTO_PROJECTID=your_project_id
VITE_OPTO_STORAGEBUCKET=your_project.appspot.com
VITE_OPTO_MESSAGINGSENDERID=your_sender_id
VITE_OPTO_APPID=your_app_id
VITE_OPTO_MEASUREMENTID=your_measurement_id

# Base URL of the Express API (Phase 1 backend).
VITE_API_URL=http://localhost:4000
